{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://ahmedmazen-spend-wise-backend.hf.space/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "unsafe-none"
        }
      ]
    }
  ]
}